{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "rootDir": "../..",
    "outDir": "./out",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmitOnError": false
  },
  "include": [
    "**/*.ts",
    "../../src/**/*.ts",
    "./old-typescript-hero/src/**/*.ts"
  ],
  "exclude": ["node_modules", "out", "../../node_modules", "old-typescript-hero/test", "old-typescript-hero/out", "old-typescript-hero/tsconfig.json", "old-typescript-hero/src/ioc.ts"]
}
