# Build artifacts (tests)
out/**
**/.vscode-test.*

# Development files
.vscode/**
.vscode-test/**
.claude/**
.editorconfig
.github/**
.gitmodules
src/**
**/*.ts
!dist/**/*.d.ts
**/tsconfig.json
**/eslint.config.mjs
esbuild.js
.gitignore
.yarnrc

# Test infrastructure (DO NOT SHIP)
comparison-test-harness/**
manual-test-cases/**

# Documentation (internal) - exclude all .md and .txt files EXCEPT README.md and CHANGELOG.md
**/*.md
**/*.txt
!README.md
!CHANGELOG.md
!LICENSE
!LICENSE.txt

# Design files
logo.svg
logo.ai

# Source maps (keep for production debugging)
# **/*.map

# Dependencies
node_modules/**
