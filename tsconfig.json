{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": [
		"src/**/*.ts",
		"tests/unit/**/*.ts"
	],
	"exclude": [
		"node_modules",
		".vscode-test",
		"tests/manual",
		"tests/comparison",
		"tests/workspaces"
	]
}
